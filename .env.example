# Vercel AI Gateway
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=openai/gpt-4.1-mini

# Redis
# Used by resumable-stream. For Upstash, use the TCP URL.
REDIS_URL=

# Used by @upstash/redis HTTP client for rate limiting/cache/simple Redis calls.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# SQL
# Use the same Postgres connection string for both until Supabase is connected.
DATABASE_URL=
SUPABASE_DATABASE_URL=

# Website assets
NEXT_PUBLIC_PLAYCANVAS_SPLAT_URL=
